  },
  "citation": {
    "preferred_citation": "Shao, C., Luo, K., Yang, Y., & Fan, J. DNS of droplet breakup in HIT (We = 15). Related article DOI: 10.1016/j.ijmultiphaseflow.2018.06.009.",
    "related_paper_doi": "10.1016/j.ijmultiphaseflow.2018.06.009",
    "authors": ["Changxiao Shao", "Kun Luo", "Yue Yang", "Jianren Fan"],
