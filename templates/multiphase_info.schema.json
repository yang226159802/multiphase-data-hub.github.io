{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiphase-data-hub.org/schemas/multiphase_info.schema.json",
  "title": "Multiphase Data Hub simulation metadata",
  "type": "object",
  "required": ["schema_version", "dataset_type", "global", "local"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "multiphase_flow_simulation"
    },
    "global": {
      "type": "object",
      "required": [
        "dataset_id",
        "title",
        "version",
        "description",
        "contributors",
        "license",
        "citation",
        "access",
        "physics",
        "numerics",
        "grid",
        "required_field_roles",
        "variables"
      ],
      "properties": {
        "dataset_id": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "contributors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "affiliation": { "type": "string" },
              "orcid": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        },
        "license": {
          "type": "object",
          "required": ["data"],
          "properties": {
            "data": { "type": "string" },
            "code": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "citation": { "type": "object" },
        "access": {
          "type": "object",
          "required": ["landing_page"],
          "properties": {
            "landing_page": { "type": "string" },
            "download_url": { "type": "string" },
            "repository_url": { "type": "string" },
            "checksums_file": { "type": "string" }
          }
        },
        "physics": {
          "type": "object",
          "required": [
            "flow_type",
            "configuration",
            "governing_equations",
            "phase_indicator_convention",
            "phases",
            "physical_parameters",
            "boundary_conditions",
            "initial_conditions"
          ],
          "properties": {
            "flow_type": { "type": "string" },
            "configuration": { "type": "string" },
            "governing_equations": { "type": "string" },
            "phase_indicator_convention": { "type": "string" },
            "phases": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            },
            "physical_parameters": {
              "type": "object",
              "description": "Case or dataset constants such as density, viscosity, surface tension, gravity, and contact angle."
            },
            "dimensionless_numbers": { "type": "object" },
            "boundary_conditions": { "type": "string" },
            "initial_conditions": { "type": "string" }
          }
        },
        "numerics": {
          "type": "object",
          "required": ["solver", "interface_method"],
          "properties": {
            "solver": { "type": "string" },
            "interface_method": {
              "enum": ["VOF", "level_set", "front_tracking", "phase_field", "SPH", "LBM", "other"]
            },
            "spatial_discretization": { "type": "string" },
            "temporal_discretization": { "type": "string" },
            "pressure_velocity_coupling": { "type": "string" },
            "interface_advection": { "type": "string" },
            "surface_tension_model": { "type": "string" },
            "time_step_policy": { "type": "string" },
            "convergence_or_resolution_notes": { "type": "string" }
          }
        },
        "grid": {
          "type": "object",
          "required": ["spatial_dimension", "grid_type", "shape", "coordinate_order", "field_location"],
          "properties": {
            "spatial_dimension": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            },
            "grid_type": { "type": "string" },
            "shape": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 }
            },
            "domain_size": { "type": "object" },
            "coordinate_order": { "type": "string" },
            "storage_order": { "type": "string" },
            "field_location": { "type": "string" },
            "coordinates": { "type": "object" }
          }
        },
        "required_field_roles": {
          "type": "object",
          "required": ["phase_indicator", "velocity", "pressure"],
          "properties": {
            "phase_indicator": { "type": "string" },
            "velocity": {
              "type": "array",
              "minItems": 2,
              "items": { "type": "string" }
            },
            "pressure": { "type": "string" }
          }
        },
        "variables": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": ["name", "role", "standard_name", "units", "shape", "dtype", "location", "required"],
            "properties": {
              "name": { "type": "string" },
              "role": {
                "enum": [
                  "phase_indicator",
                  "velocity_component",
                  "pressure",
                  "temperature",
                  "species_or_concentration",
                  "derived_interface_geometry",
                  "derived_diagnostic",
                  "material_property_field",
                  "other"
                ]
              },
              "standard_name": { "type": "string" },
              "description": { "type": "string" },
              "units": { "type": "string" },
              "shape": {
                "type": "array",
                "items": { "type": ["string", "integer"] }
              },
              "dtype": { "type": "string" },
              "location": { "type": "string" },
              "valid_range": { "type": "array" },
              "required": { "type": "boolean" }
            }
          }
        },
        "splits": { "type": "object" },
        "known_limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "local": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "case_id", "snapshot_id", "time", "files"],
        "properties": {
          "id": { "type": ["integer", "string"] },
          "case_id": { "type": "string" },
          "snapshot_id": { "type": ["integer", "string"] },
          "time": { "type": "object" },
          "files": { "type": "object" },
          "case_parameters": { "type": "object" }
        }
      }
    }
  }
}
